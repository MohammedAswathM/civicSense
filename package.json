{
  "name": "civicsense",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/check-env.cjs || true",
    "dev": "next dev",
    "dev:e2e": "next dev -H 127.0.0.1 -p 3100",
    "dev:emulators": "concurrently \"firebase emulators:start\" \"npm run dev\"",
    "dev:full": "concurrently \"firebase emulators:start --import=./demo-data --export-on-exit=./demo-data\" \"npm run dev\"",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "eslint src tests scripts functions/src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "precommit": "npm run lint && npm run typecheck",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:unit": "node ./node_modules/vitest/vitest.mjs run tests/unit",
    "test:integration": "node scripts/require-java.cjs && node ./node_modules/firebase-tools/lib/bin/firebase.js emulators:exec --only firestore,auth,storage \"node ./node_modules/vitest/vitest.mjs run tests/integration\"",
    "test:e2e": "node scripts/require-java.cjs && node ./node_modules/firebase-tools/lib/bin/firebase.js emulators:exec --only firestore,auth,storage \"NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true NEXT_PUBLIC_DEMO_MODE=true node ./node_modules/playwright/cli.js test\"",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:smoke": "tsx scripts/smoke-test.ts",
    "seed:demo": "tsx scripts/seed-demo-data.ts",
    "check-env": "node scripts/check-env.cjs"
  },
  "dependencies": {
    "@google/genai": "^1.8.0",
    "@googlemaps/js-api-loader": "^1.16.8",
    "@googlemaps/markerclusterer": "^2.5.3",
    "browser-image-compression": "^2.0.2",
    "chart.js": "^4.4.3",
    "firebase": "^10.12.4",
    "geofire-common": "^6.0.0",
    "next": "14.2.5",
    "next-pwa": "^5.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.2",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "firebase-admin": "^12.2.0",
    "firebase-functions": "^5.0.1",
    "firebase-tools": "^11.30.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.39",
    "prettier": "^3.3.2",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
